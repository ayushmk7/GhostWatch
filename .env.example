# GhostWatch — copy to .env and fill in. `jac start` loads this file automatically via python-dotenv (see main.jac).
#
# Shared (System 1 + System 2): GitHub API, webhooks, LLM, Discord
# -----------------------------------------------------------------
# System 2 uses these for: manifest/PR GitHub calls, HMAC on the System 2 webhook,
# by llm() (sandbox interpretation, fix PR body, gap wording), and incident / escalation / gap Discord alerts.

# Demo UI repo is hardcoded to https://github.com/jaseci-labs/jaseci (GHOSTWATCH_DEMO_REPO_URL is unused).

GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_WEBHOOK_SECRET=REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# System 2 optional (design / manual use)
# --------------------------------------
# E2B is called out in docs/system2design.md for isolated sandboxes. The current codebase uses a
# local subprocess instrumented runner instead; keep this key here if you wire E2B later or use it manually.

E2B_API_KEY=e2b_REPLACE_ME
